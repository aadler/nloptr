ProjectId: 6a9451dd-0c75-4b9d-871a-4e949446b9c7

RestoreWorkspace: No
SaveWorkspace: No
AlwaysSaveHistory: Default

EnableCodeIndexing: Yes
UseSpacesForTab: Yes
NumSpacesForTab: 2
Encoding: UTF-8

RnwWeave: Sweave
LaTeX: pdfLaTeX

AutoAppendNewline: Yes
StripTrailingWhitespace: Yes
LineEndingConversion: Posix

BuildType: Package
PackageUseDevtools: Yes
PackageInstallArgs: --no-multiarch --with-keep.source --clean  --preclean
PackageBuildArgs: --md5 --compact-vignettes
PackageBuildBinaryArgs: --clean  --preclean
PackageCheckArgs: --as-cran --timings
PackageRoxygenize: rd,collate,namespace
